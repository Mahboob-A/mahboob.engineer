# .env.example — copy to .env.local for local dev. Do NOT commit .env.local.
#
# Production secrets live in Vercel → Project Settings → Environment Variables.
# See docs/DEPLOY.md for the full setup checklist.

# ─── Public site URL ─────────────────────────────────────────────────────────
# Override for local dev (default: https://mahboob.engineer). Used by
# lib/og-helpers.ts and lib/metadata.ts for OG image absolute URLs.
NEXT_PUBLIC_SITE_URL=https://mahboob.engineer

# ─── Contact form (Resend) ──────────────────────────────────────────────────
# Free tier: https://resend.com/api-keys. Sender is `onboarding@resend.dev`
# until a custom domain (e.g. noreply@mahboob.engineer) is verified in the
# Resend dashboard. Without this var, /api/contact returns 500 and the form
# shows the mailto fallback.
RESEND_API_KEY=

# ─── Keystatic admin (production only; dev uses local storage) ──────────────
# 1. Create an OAuth App on GitHub:
#    https://github.com/settings/developers → New OAuth App
#    Homepage URL:               https://mahboob.engineer
#    Callback URL:               https://mahboob.engineer/api/keystatic/github/oauth/callback
# 2. Copy the client ID + client secret.
# 3. Generate KEYSTATIC_SECRET as 32 random bytes (e.g. `openssl rand -hex 32`).
# 4. Paste all values into Vercel → Environment Variables.
KEYSTATIC_SECRET=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_GITHUB_REPO_OWNER=Mahboob-A
KEYSTATIC_GITHUB_REPO_NAME=my-portfolio

# ─── RAG-LLM terminal (Phase 7 v2 — NOT YET ENABLED) ─────────────────────────
# The hero terminal currently ships in static mode (chips → pre-canned
# payloads). To upgrade to a real LLM-backed chat that "knows about me",
# set the env vars below AND follow docs/RAG_TERMINAL.md to wire
# app/api/rag/route.ts + scripts/rag-reindex.mjs.
#
# OPENAI_API_KEY    — from https://platform.openai.com/api-keys
# UPSTASH_VECTOR_*  — from https://upstash.com → Vector (free tier is enough).
#                     REST_URL is the public endpoint; REST_TOKEN authenticates.
#
# Cost estimate (text-embedding-3-small + gpt-4o-mini):
#   ~$0.10 per 1000 queries.
#   For a portfolio with ~100 queries/month, that's $0.01/mo.
OPENAI_API_KEY=
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
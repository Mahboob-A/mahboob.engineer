# .env.example — copy to .env.local for local dev. Do NOT commit .env.local.
#
# Production secrets live in Vercel → Project Settings → Environment Variables.
# See docs/DEPLOY.md for the full setup checklist.

# ─── Public site URL ─────────────────────────────────────────────────────────
# Override for local dev (default: https://mahboob.engineer). Used by
# lib/og-helpers.ts and lib/metadata.ts for OG image absolute URLs.
NEXT_PUBLIC_SITE_URL=https://mahboob.engineer

# ─── Contact form (Resend) ──────────────────────────────────────────────────
# Free tier: https://resend.com/api-keys. Sender is `onboarding@resend.dev`
# until a custom domain (e.g. noreply@mahboob.engineer) is verified in the
# Resend dashboard. Without this var, /api/contact returns 500 and the form
# shows the mailto fallback.
RESEND_API_KEY=

# ─── Keystatic admin (production only; dev uses local storage) ──────────────
# 1. Create an OAuth App on GitHub:
#    https://github.com/settings/developers → New OAuth App
#    Homepage URL:               https://mahboob.engineer
#    Callback URL:               https://mahboob.engineer/api/keystatic/github/oauth/callback
# 2. Copy the client ID + client secret.
# 3. Generate KEYSTATIC_SECRET as 32 random bytes (e.g. `openssl rand -hex 32`).
# 4. Paste all values into Vercel → Environment Variables.
KEYSTATIC_SECRET=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_GITHUB_REPO_OWNER=Mahboob-A
KEYSTATIC_GITHUB_REPO_NAME=my-portfolio

# ─── RAG terminal (Phase 33; static mode remains default) ───────────────────
# Dynamic mode uses a provider adapter selected by LLM_PROVIDER. Fireworks is
# the first implementation target because the API is OpenAI-compatible and
# Mahboob has Fireworks credits. See docs/rag/PROVIDERS.md.
LLM_PROVIDER=fireworks
FIREWORKS_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
RAG_CHAT_MODEL=accounts/fireworks/models/gpt-oss-120b
# Embeddings are owned by Upstash Vector (server-side). These two vars must
# match what you selected at index creation in the Upstash console. The index
# is dimension-locked; changing the model later requires recreating the index.
RAG_UPSTASH_EMBEDDING_MODEL=openai/text-embedding-3-small
RAG_UPSTASH_EMBEDDING_DIMENSIONS=1536
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
# Per-IP rate limit for /api/rag. In-memory; resets on cold start.
# Default 20/hour. Bump for a demo, lower for stricter abuse control.
RAG_RATE_LIMIT_PER_HOUR=20

# ─── Upstash Redis (For RAG Rate Limiting) ───────────────────────────────────
# Create a free Redis database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Langfuse Observability ──────────────────────────────────────────────────
# Create a free project at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

